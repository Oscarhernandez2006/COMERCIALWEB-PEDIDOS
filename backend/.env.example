# App
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=comercial
DB_SYNCHRONIZE=true
DB_LOGGING=false

# JWT
JWT_SECRET=change_this_super_secret_in_production
JWT_EXPIRES_IN=1d

# Siesa API
SIESA_BASE_URL=https://api.siesa.com
SIESA_CONNI_KEY=
SIESA_CONNI_TOKEN=
SIESA_USERNAME=
SIESA_PASSWORD=
SIESA_COMPANY_ID=
SIESA_TIMEOUT_MS=15000
